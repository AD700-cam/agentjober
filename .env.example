# =======================================================
# AI Career Assistant - Environment Variables Template
# Copy this file to '.env' and fill in your values
# =======================================================

# 🧠 Gemini API Integration (Required)
# Generate a free key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 📢 Real-Time Alerting Notifications (Optional)
# Paste your Discord server webhook channel URL:
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Or set up your Telegram Bot notifications:
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
